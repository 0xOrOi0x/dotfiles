#!/usr/bin/env bash
# =============================================================================
# 🪄 install — One-line entry point for 0xOrOi0x/dotfiles
# -----------------------------------------------------------------------------
# Usage:
#   sh -c "$(curl -fsSL https://raw.githubusercontent.com/0xOrOi0x/dotfiles/main/install)"
#
# What this does:
#   1. Verify macOS
#   2. Install Xcode CLT (if missing) — provides git
#   3. Clone or update the dotfiles repo to ~/.dotfiles
#   4. Hand off to bootstrap.sh
# =============================================================================
set -euo pipefail

readonly REPO_URL="https://github.com/0xOrOi0x/dotfiles.git"
readonly DOTFILES_DIR="${DOTFILES_DIR:-$HOME/.dotfiles}"
readonly BRANCH="${BRANCH:-main}"

# ─── Color helpers ──────────────────────────────────────────────────────────
C_BLUE='\033[0;34m'; C_GREEN='\033[0;32m'; C_YELLOW='\033[1;33m'
C_RED='\033[0;31m'; C_BOLD='\033[1m'; C_RESET='\033[0m'
log()  { printf "${C_BLUE}▸${C_RESET} %s\n" "$*"; }
ok()   { printf "${C_GREEN}✓${C_RESET} %s\n" "$*"; }
warn() { printf "${C_YELLOW}⚠${C_RESET} %s\n" "$*"; }
die()  { printf "${C_RED}✗${C_RESET} %s\n" "$*" >&2; exit 1; }

# ─── Banner ─────────────────────────────────────────────────────────────────
cat <<BANNER
${C_BOLD}
  ╭───────────────────────────────────────────────────────╮
  │   🪄  0xOrOi0x/dotfiles — One-Line Installer          │
  │   Multi-Agent Dev Environment v3.1                    │
  ╰───────────────────────────────────────────────────────╯
${C_RESET}
BANNER

# ─── Pre-flight ─────────────────────────────────────────────────────────────
[[ "$(uname)" == "Darwin" ]] || die "This installer only supports macOS."

log "Detected macOS $(sw_vers -productVersion) on $(uname -m)"

# ─── Xcode Command Line Tools (provides git) ────────────────────────────────
xcode_clt_ready() {
  xcode-select -p &>/dev/null && xcrun --find git &>/dev/null
}

if ! xcode_clt_ready; then
  log "Installing Xcode Command Line Tools..."
  xcode-select --install 2>/dev/null || true

  warn "A GUI dialog has appeared — click 'Install' and wait for completion."
  warn "After installation finishes, RE-RUN this command to continue."
  echo
  echo "  sh -c \"\$(curl -fsSL https://raw.githubusercontent.com/0xOrOi0x/dotfiles/${BRANCH}/install)\""
  echo
  exit 0
fi
ok "Xcode Command Line Tools present"

# ─── Clone or update repo ───────────────────────────────────────────────────
if [[ -d "$DOTFILES_DIR/.git" ]]; then
  log "Updating existing dotfiles repo at $DOTFILES_DIR..."
  git -C "$DOTFILES_DIR" fetch origin "$BRANCH"
  git -C "$DOTFILES_DIR" reset --hard "origin/$BRANCH"
  ok "Repo updated"
else
  if [[ -d "$DOTFILES_DIR" ]]; then
    warn "$DOTFILES_DIR exists but is not a git repo. Backing up..."
    mv "$DOTFILES_DIR" "${DOTFILES_DIR}.backup-$(date +%Y%m%d-%H%M%S)"
  fi
  log "Cloning $REPO_URL → $DOTFILES_DIR..."
  git clone --branch "$BRANCH" "$REPO_URL" "$DOTFILES_DIR"
  ok "Repo cloned"
fi

# ─── Hand off to bootstrap ──────────────────────────────────────────────────
log "Handing off to bootstrap.sh..."
echo

exec bash "$DOTFILES_DIR/bootstrap.sh" "$@"
