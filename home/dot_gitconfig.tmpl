{{/* ~/.gitconfig — managed by chezmoi */ -}}
[user]
    name = {{ .name }}
    email = {{ .email }}

[init]
    defaultBranch = main

[core]
    pager = delta
    editor = nvim
    autocrlf = input

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    side-by-side = true
    line-numbers = true
    syntax-theme = Catppuccin-Mocha

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[push]
    default = current
    autoSetupRemote = true

[pull]
    rebase = true

[fetch]
    prune = true

[rebase]
    autoStash = true
    autoSquash = true

[credential]
    helper = osxkeychain

# GitHub CLI
[hub]
    protocol = https

# Aliases
[alias]
    co = checkout
    br = branch
    ci = commit
    st = status
    last = log -1 HEAD
    unstage = reset HEAD --
    visual = !gitk
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit

{{- if eq .machine "work" }}
# Work-specific (e.g., separate signing key, different protocol)
# [user]
#     signingkey = <work-key>
{{- end }}
