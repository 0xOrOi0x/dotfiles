{{/* tmux config — managed by chezmoi v3.2 */ -}}
# tmux — Persistence Layer for Ghostty
# Machine: {{ .machine }} ({{ .profile }} profile)

unbind C-b
set -g prefix C-Space
bind C-Space send-prefix

set -g default-terminal "tmux-256color"
set -as terminal-overrides ",*:Tc"
set -g mouse on
set -g base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g escape-time 0

# Machine-specific history limit
{{ if eq .profile "full" -}}
set -g history-limit 500000
{{ else -}}
set -g history-limit 100000
{{- end }}

set -g focus-events on

# Vim navigation
bind h select-pane -L
bind j select-pane -D
bind k select-pane -U
bind l select-pane -R

# Splits inherit current path
bind | split-window -h -c "#{pane_current_path}"
bind - split-window -v -c "#{pane_current_path}"

# Multi-agent shortcuts
bind S display-popup -E "glow ~/.agents/status/*.md 2>/dev/null || echo 'No agents active'"
bind A display-popup -E "glow $(git rev-parse --show-toplevel 2>/dev/null)/AGENTS.md 2>/dev/null || echo 'Not in a git repo'"
bind R display-popup -E "ls ~/.agents/reviews/ 2>/dev/null | fzf | xargs -I{} glow ~/.agents/reviews/{}"
bind W display-popup -E "git worktree list | fzf | awk '{print \$1}' | xargs -I{} tmux send-keys 'cd {}' Enter"
bind g display-popup -E -w 90% -h 90% "lazygit"
bind I display-popup -E "echo 'Machine: {{ .machine }}' && echo 'Profile: {{ .profile }}' && echo 'Chip:    {{ .chip }}' && echo 'RAM:     {{ .ram_gb }}GB'"

bind C-s setw synchronize-panes \; display "Sync: #{?pane_synchronized,ON,OFF}"
bind r source-file ~/.tmux.conf \; display "🔁 Reloaded"

# Status bar (Catppuccin Mocha) with machine ID
set -g status-style "bg=#1e1e2e,fg=#cdd6f4"
set -g status-left-length 50
set -g status-left "#[bg=#cba6f7,fg=#1e1e2e,bold] 󰊠 #S #[bg=#1e1e2e,fg=#cba6f7] {{ if .is_apple_silicon }}🪶{{ else }}💪{{ end }} {{ .machine }} "
set -g status-right "#[fg=#89b4fa]#(~/.tmux/scripts/agent-status.sh) #[fg=#a6e3a1]%H:%M "
setw -g window-status-current-format "#[bg=#89b4fa,fg=#1e1e2e,bold] #I:#W "
setw -g window-status-format "#[fg=#7f849c] #I:#W "

# Plugins
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'tmux-plugins/tmux-yank'

set -g @resurrect-capture-pane-contents 'on'
set -g @continuum-restore 'on'
set -g @continuum-save-interval '15'

run '~/.tmux/plugins/tpm/tpm'
